# Required: Anthropic API key for answer generation
ANTHROPIC_API_KEY=your-api-key-here

# Optional: API key to gate access to all endpoints (except /health)
# When not set, the API runs in open-access mode (backwards-compatible)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECONDBRAIN_API_KEY=

# Optional: Allowed CORS origins (comma-separated)
# Default: http://localhost:3000,http://localhost:8501
CORS_ORIGINS=

# Optional: Rate limit (requests per hour per IP)
# Default: 60
SECONDBRAIN_RATE_LIMIT=60
